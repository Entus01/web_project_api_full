{
  "extends": "airbnb-base",
  "rules": {
    "camelcase": "off",
    "no-underscore-dangle": [
      "error",
      { "allow": ["_id"], "allowAfterThis": true, "allowAfterSuper": true }
    ],
    "no-console": ["warn", { "allow": ["log"] }],
    "no-unused-vars": ["error", { "argsIgnorePattern": "next" }],
    "linebreak-style": ["off"]
  }
}
